# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# API
API_URL=http://localhost:3001
RIND_SECRET_KEY=change-me

# Proxy
PROXY_PORT=7777
RIND_API_KEY=local-dev-key

# ─── Simulation (tools/simulation/) ──────────────────────────────────────────

# Rind proxy URL for simulation agents (leave empty to bypass proxy)
# RIND_URL=http://localhost:7777

# LLM provider for simulation — pick one:
# Groq (free tier, recommended for local dev)
GROQ_API_KEY=gsk_xxx

# Google Gemini (free tier — 15 req/min)
# GOOGLE_API_KEY=xxx

# OpenAI GPT-4o-mini (cheap — $0.15/1M tokens)
# OPENAI_API_KEY=sk-xxx

# Anthropic Claude (premium — for demos)
# ANTHROPIC_API_KEY=sk-ant-xxx

# DeepSeek (very cheap — $0.14/1M tokens)
# DEEPSEEK_API_KEY=sk-xxx
